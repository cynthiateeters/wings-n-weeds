---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Fix UTC offset, parse as local date
const [year, month, day] = post.data.date.toISOString().split('T')[0].split('-').map(Number);
const localDate = new Date(year, month - 1, day);
const formattedDate = localDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={`${post.data.title}, Wings & Weed Co.`} description={post.data.description}>
  <section class="section">
    <div class="container">
      <a href="/log" class="back-link">&larr; All Field Notes</a>

      <article class="post-body">
        <h1>{post.data.title}</h1>

        <div class="byline">
          <div class="byline-avatars">
            <div class="byline-avatar">
              <img src="/images/cynthia-pip.png" alt="Cynthia" />
              <span>Cynthia</span>
            </div>
            <div class="byline-avatar">
              <img src="/images/nancy.png" alt="Nancy" />
              <span>Nancy</span>
            </div>
          </div>
          <div class="byline-meta">
            <p class="byline-credit">{post.data.author ? `by ${post.data.author}` : 'by Wings & Weed Co.'}</p>
            <p class="byline-date">{formattedDate}</p>
          </div>
        </div>

        <div class="post-content">
          <Content />
        </div>
      </article>
    </div>
  </section>
</Base>

<style>
  .byline {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-block: 1.5rem 2.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-card);
    border-radius: var(--radius-md);
  }

  .byline-avatars {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .byline-avatar {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .byline-avatar img {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    border: 3px solid var(--color-peach);
    object-fit: cover;
    background: var(--color-peach);
  }

  .byline-avatar span {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--color-charcoal);
    opacity: 0.75;
  }

  .byline-meta {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .byline-credit {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-charcoal);
  }

  .byline-date {
    font-size: 0.9rem;
    color: var(--color-charcoal);
    opacity: 0.6;
  }
</style>
